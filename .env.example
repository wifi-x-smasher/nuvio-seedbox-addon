# Copy this file to .env and fill in real values. .env is gitignored.

# --- Add-on server ---
ADDON_PORT=7700
# Poster source preference: "better" (BetterPosters -> RPDB -> TMDB, default),
# "rpdb" (RPDB rating-posters first), or "tmdb" (plain TMDB only).
POSTER_SOURCE=
# Public base URL the add-on is reachable at (used to build subtitle relay URLs).
# Example once deployed on Whatbox: https://yourbox.whatbox.ca:7700
ADDON_BASE_URL=http://127.0.0.1:7700
# Secret path segment gating access. STRONGLY recommended before exposing the
# add-on publicly: stream responses include your Whatbox credentials, so the URL
# must not be guessable. With it set, install URL is <base>/<secret>/manifest.json.
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADDON_SECRET=
# Admin panel password (HTTP Basic), separate from ADDON_SECRET so a shared
# manifest URL can't open admin. Panel is at <base>/<secret>/admin. Unset = off.
ADMIN_PASSWORD=

# Library folders under the base URL that hold your media (comma-separated).
MOVIE_DIRS=Movies
SERIES_DIRS=TV Shows

# --- Seedbox access (any seedbox exposing an HTTP file index + Basic auth) ---
# The HTTP auto-index ("Index of /private/") base URL that serves your files.
# Confirmed to support range/seeking and HTTP Basic auth.
# Example: https://yourbox.host/private/
WHATBOX_HTTP_BASE_URL=
# HTTP Basic auth (the username/password the player prompts for).
WHATBOX_HTTP_USER=
WHATBOX_HTTP_PASS=
# Optional: absolute local path to the library ON the box. Only needed if we
# later switch the scanner from HTTP auto-index reading to a direct filesystem
# scan. Leave blank for now.
WHATBOX_LIBRARY_PATH=

# --- Metadata keys (server-side only, never exposed to clients) ---
TMDB_API_KEY=
TVDB_API_KEY=
RPDB_API_KEY=
MDBLIST_API_KEY=
GEMINI_API_KEY=
# Optional. Gemini model for the fallback matcher. Default gemini-flash-latest
# (works on the free tier). For best results enable BILLING on the API project
# (separate from a Google AI Pro app subscription) and set gemini-2.5-pro or
# gemini-2.5-flash here — without billing those return HTTP 429 (quota 0).
GEMINI_MODEL=

# --- TLS (serve the add-on over HTTPS) ---
# Point these at a cert/key whose name matches your public URL. On Whatbox the
# wildcard cert works for any *.<server>.box.ca host.
TLS_CERT=
TLS_KEY=
# Where the index + caches live (persistent path). Default: ./data
DATA_DIR=
# Auto re-index interval in hours (default 12).
SCAN_INTERVAL_HOURS=
# Auto re-index interval in MINUTES (overrides SCAN_INTERVAL_HOURS if set).
SCAN_INTERVAL_MINUTES=
