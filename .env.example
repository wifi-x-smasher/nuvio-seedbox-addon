# Copy this file to .env and fill in your values. .env is gitignored.
# Most of these can also be edited later from the admin panel (no restart).

# --- Add-on ---
# Display name (manifest title + admin + stream source label).
ADDON_NAME=Seedbox Library
ADDON_PORT=7700
# Public URL the add-on is reachable at (used to build subtitle relay links).
# e.g. https://addon.example.com  or  https://yourbox.host:PORT
ADDON_BASE_URL=http://127.0.0.1:7700
# Secret path segment gating access. STRONGLY recommended before exposing the
# add-on publicly: stream responses include your seedbox credentials, so the URL
# must not be guessable. Install URL becomes <base>/<secret>/manifest.json.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADDON_SECRET=
# Admin panel password (HTTP Basic), separate from ADDON_SECRET. Panel is at
# <base>/<secret>/admin. Unset = admin disabled.
ADMIN_PASSWORD=

# --- Seedbox (any seedbox that exposes an HTTP file index + Basic auth) ---
# The "Index of …" base URL that serves your files (range/seeking supported).
# e.g. https://yourbox.host/private/
SEEDBOX_HTTP_BASE_URL=
SEEDBOX_HTTP_USER=
SEEDBOX_HTTP_PASS=
# Folders under the base URL that hold your media (comma-separated).
MOVIE_DIRS=Movies
SERIES_DIRS=TV Shows

# --- Metadata ---
TMDB_API_KEY=
# Optional. RPDB rating-posters.
RPDB_API_KEY=
# Optional. Gemini fallback matcher for hard/foreign titles.
GEMINI_API_KEY=
# Optional. Default gemini-flash-latest (free-tier friendly).
GEMINI_MODEL=
# Poster source: "better" (BetterPosters->RPDB->TMDB, default), "rpdb", or "tmdb".
POSTER_SOURCE=

# --- TLS (optional; serve HTTPS directly) ---
# A cert/key whose name matches ADDON_BASE_URL's host. Leave blank to use plain
# HTTP (fine behind a reverse proxy that terminates TLS).
TLS_CERT=
TLS_KEY=

# --- Storage / scheduling ---
# Persistent path for index + caches. Default: ./data
DATA_DIR=
# Auto re-index interval in minutes (default 720 = 12h).
SCAN_INTERVAL_MINUTES=
